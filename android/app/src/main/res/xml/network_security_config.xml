<?xml version="1.0" encoding="utf-8"?>
<!--
    PTRZN-1515: Configuração de segurança de rede para forçar HTTPS.
    SSL/HTTPS agora é tratado pelo Nginx com certificados Let's Encrypt válidos.
-->
<network-security-config>
    <!-- Configuração base: força HTTPS e confia apenas em certificados do sistema -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Confia apenas em certificados do sistema (inclui Let's Encrypt) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
